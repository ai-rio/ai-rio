{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/app/[locale]/globals.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@scrollxui": "https://www.scrollxui.dev/registry/{name}.json",
    "@tailark": "https://tailark.com/registry/{name}.json",
    "@effector": "https://effector.design/r/{name}.json",
    "@shadcnui-blocks": "https://www.shadcnui-blocks.com/r/{name}.json"
  }
}
